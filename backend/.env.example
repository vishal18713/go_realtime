# ==========================================
# Inox Backend Service Environment (.env.example)
# ==========================================
# Copy this file to .env and configure the variables for your environment:
#   cp .env.example .env

# --- Core Application Settings ---
# APP_ENV: development | staging | production
APP_ENV=development
# HTTP_PORT: Port for the REST API and WebSocket server
HTTP_PORT=8080
# LOG_LEVEL: debug | info | warn | error
LOG_LEVEL=debug

# --- Database & Caching Connections (REQUIRED) ---
# DATABASE_URL: PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/inox?sslmode=disable
# REDIS_URL: Redis connection URI for session storage and cache
REDIS_URL=redis://localhost:6379/0

# --- Authentication & Session Security ---
# SESSION_SECRET: Cryptographically secure secret used for session management / token signing
SESSION_SECRET=supersecretkey1234567890abcdefghijklmnopqrstuvwxyz
# SESSION_DURATION_HOURS: Session time-to-live in hours (default: 168 hours / 7 days)
SESSION_DURATION_HOURS=168

# --- Local Storage & Media Streaming ---
# STORAGE_DIR: Local directory path where uploaded media and processed HLS chunks are stored
STORAGE_DIR=./storage_data
# MEDIA_STREAM_BASE_URL: Public base URL for serving processed media streams
MEDIA_STREAM_BASE_URL=http://localhost:8080/media/stream

# --- MinIO Object Storage Configuration ---
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=inox-media

# --- Security & CORS Configuration ---
# CORS_ALLOWED_ORIGINS: Comma-separated list of allowed frontend origins for CORS and HttpOnly cookies
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# --- WebRTC SFU Media Engine Configuration ---
# WEBRTC_ICE_SERVERS: Comma-separated list of STUN and TURN servers for ICE negotiation
WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# WEBRTC_PORT_MIN / WEBRTC_PORT_MAX: UDP port range for media RTP relay
WEBRTC_PORT_MIN=50000
WEBRTC_PORT_MAX=50100
