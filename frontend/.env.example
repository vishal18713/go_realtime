# ==========================================
# Inox Watch Party Frontend Environment (.env.example)
# ==========================================
# Copy this file to .env and configure values for your setup:
#   cp .env.example .env

# --- API & WebSocket Endpoints ---
# VITE_API_BASE_URL: Base HTTP endpoint for REST API requests to the Go backend
VITE_API_BASE_URL=http://localhost:8080/api/v1
# VITE_WS_BASE_URL: Base WebSocket protocol and domain prefix for real-time room signaling
VITE_WS_BASE_URL=ws://localhost:8080/api/v1

# --- Application Configuration ---
VITE_APP_NAME="Inox Watch Party"
VITE_LOG_LEVEL=debug

# --- Media & Storage Endpoints ---
# VITE_MEDIA_STREAM_BASE_URL: Base URL for serving HLS video playlists and chunks
VITE_MEDIA_STREAM_BASE_URL=http://localhost:8080/media/stream
# VITE_MINIO_CONSOLE_URL: Endpoint for accessing the MinIO storage console
VITE_MINIO_CONSOLE_URL=http://localhost:9001
