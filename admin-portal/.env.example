# ==========================================
# Inox Admin Portal Environment (.env.example)
# ==========================================
# Copy this file to .env and configure values for your dashboard:
#   cp .env.example .env

# --- API & Telemetry Endpoints ---
# VITE_API_BASE_URL: Base HTTP endpoint for admin REST API requests
VITE_API_BASE_URL=http://localhost:8080/api/v1
# VITE_TELEMETRY_WS_URL: Real-time system pulse telemetry WebSocket URL
VITE_TELEMETRY_WS_URL=ws://localhost:8080/api/v1/admin/telemetry/ws

# --- CDN & Storage Endpoints ---
# VITE_CDN_BASE_URL: CDN endpoint for streaming HLS media catalogs and assets
VITE_CDN_BASE_URL=https://cdn.inox.stream
# VITE_MINIO_BASE_URL: Endpoint for direct object storage / MinIO access
VITE_MINIO_BASE_URL=http://localhost:9000

# --- Dashboard & Debug Options ---
# VITE_ENABLE_DEMO_MODE: Set to true to run system pulse dashboard with simulated telemetry
VITE_ENABLE_DEMO_MODE=false
VITE_LOG_LEVEL=debug
